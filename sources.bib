
@article{yungelson_elusive_2024,
	title = {Elusive hot stripped helium stars in the {Galaxy} - {I}. {Evolutionary} stellar models in the gap between subdwarfs and {Wolf}-{Rayet} stars},
	volume = {683},
	copyright = {© The Authors 2024},
	issn = {0004-6361, 1432-0746},
	url = {https://www.aanda.org/articles/aa/abs/2024/03/aa47806-23/aa47806-23.html},
	doi = {10.1051/0004-6361/202347806},
	abstract = {{\textless}i{\textgreater}Context.{\textless}i/{\textgreater} Stellar evolution theory predicts the existence of helium-core remnants of the primary components of intermediate-mass close binaries that lost most of their hydrogen-helium envelopes due to the mass exchange. These remnants are expected to be observed as hot helium-rich stars with masses of (1−7) {\textless}i{\textgreater}M{\textless}i/{\textgreater}{\textless}sub{\textgreater}⊙{\textless}sub/{\textgreater}, located in the area of the Hertzsprung-Russell diagram between OB subdwarfs and Wolf-Rayet stars. While several thousands of such stripped helium stars are expected to exist in the Galaxy, none of them have been identified so far.{\textless}i{\textgreater}Aims.{\textless}i/{\textgreater} We aim to provide comprehensive predictions of the numbers and fundamental properties of stripped helium stars and their binary companions in the Galaxy. This is a necessary first step to guide observations, to enable a comparison between binary evolution models and realistic stellar populations, and to determine the feedback parameters of stripped helium stars in the Galaxy.{\textless}i{\textgreater}Methods.{\textless}i/{\textgreater} We expanded the previously considered space of parameters describing close binary systems producing stripped helium stars and applied a population synthesis based on a grid of evolutionary models computed by the code MESA, using a spin-dependent algorithm for the treatment of mass and angular momentum loss from the system.{\textless}i{\textgreater}Results.{\textless}i/{\textgreater} We show that the number of Galactic binaries hosting (1−7) {\textless}i{\textgreater}M{\textless}i/{\textgreater}{\textless}sub{\textgreater}⊙{\textless}sub/{\textgreater} He-stars is ≃20 000 and that it steeply declines with an increase in the He-star mass (≃3000 with mass ≳2 {\textless}i{\textgreater}M{\textless}i/{\textgreater}{\textless}sub{\textgreater}⊙{\textless}sub/{\textgreater}). The decisive factor that defines the low number of stripped He-stars is runaway mass-loss after Roche lobe overflow (RLOF) by primary components of the binaries, which leads to the formation of common envelopes and the further merger of components. This effect strongly restricts the initial ranges of masses of components of the progenitors of stripped stars and orbital periods. In addition, stripped helium stars are much less numerous than expected, since a significant fraction of binaries in which the primaries have masses less than (5−7) {\textless}i{\textgreater}M{\textless}i/{\textgreater}{\textless}sub{\textgreater}⊙{\textless}sub/{\textgreater} produce subdwarfs with masses ≲1 {\textless}i{\textgreater}M{\textless}i/{\textgreater}{\textless}sub{\textgreater}⊙{\textless}sub/{\textgreater}. Our calculations show that the overwhelming majority of helium stars reside in binaries with an early-type companion star and can be identified neither by the UV excess nor by emission features. The large periods of a significant fraction of binaries hosting stripped stars (≳several hundred days) also hamper their discovery.},
	language = {en},
	urldate = {2025-11-18},
	journal = {Astronomy \& Astrophysics},
	author = {Yungelson, L. and Kuranov, A. and Postnov, K. and Kuranova, M. and Oskinova, L. M. and Hamann, W.-R.},
	month = mar,
	year = {2024},
	note = {Publisher: EDP Sciences},
	pages = {A37},
	file = {Full Text PDF:/home/pierson/snap/zotero-snap/common/Zotero/storage/874KQ57V/Yungelson et al. - 2024 - Elusive hot stripped helium stars in the Galaxy - I. Evolutionary stellar models in the gap between.pdf:application/pdf},
}

